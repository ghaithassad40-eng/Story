# ─── StoryMagic Kids — Environment Variables ───────────────────────────────
# Copy this file and rename it to .env, then fill in your API keys below.
# Never commit .env to git — it is already in .gitignore.

# ── OpenRouter (required) ────────────────────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=

# ── Lumen AI (required for story illustrations) ──────────────────────────────
# Get your key at: https://app.lumenpro.io
VITE_LUMEN_API_KEY=

# ── ElevenLabs (required for story narration) ────────────────────────────────
# Get your key at: https://elevenlabs.io → Profile → API Keys
VITE_ELEVENLABS_API_KEY=
